{% assign bundle_products = shop.metafields.app.products.value%}
<div class="bundle-products__wrapper">
  <h2 style="text-align: center">Bundle builder</h2>
  {% if bundle_products.size > 0 %}
    <div class="bundle-products-list">
      {% for product in bundle_products %}
        <div class="bundle-product-item">
          {{ product | image_url: width: 500 | image_tag: class: 'bundle-product-image', alt: product.title }}
          <p style="font-weight: bold; margin-top: 10px;">{{ product.title }}</p>
          <p>{{ product.price | money }}</p>
        </div>
      {% endfor %}
    </div>

    <button id="add-bundle-to-cart" onclick="addBundleToCart()">
      Add Bundle to Cart
    </button>
  {% else %}
    <p>Bundle is currently empty. Please check back later!</p>
  {% endif %}
</div>

<style>
  .bundle-products__wrapper {
    margin: 60px auto;
  }

  .bundle-products-list {
    display: grid;
    gap: 20px;
    margin-bottom: 20px;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .bundle-product-item {
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 8px;
  }
  
  .bundle-product-image {
    aspect-ratio: 1 / 1;
    object-fit: contain;
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  #add-bundle-to-cart{
    background: #000; 
    color: #fff; 
    padding: 12px 24px; 
    border: none; 
    border-radius: 4px; 
    cursor: pointer; 
    width: 100%;
  }
</style>

<script>
  document.querySelector('#add-bundle-to-cart').addEventListener('click', async function(e) {
    e.preventDefault();
    const btn = e.target;
    const originalText = btn.innerText;
    
    btn.innerText = 'Adding...';
    btn.disabled = true;

    const bundleGroupId = `bundle_${Date.now()}`;

    const items = [
      {% for product in bundle_products %}
        {
          id: {{ product.first_available_variant.id }},
          quantity: 1,
          properties: {
            "_bundle_group": bundleGroupId, 
            "Bundle": "Custom Set"         
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    try {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      });

      if (!response.ok) {
        throw new Error('Error adding bundle to cart');
      }
    } catch (error) {
      console.error('Bundle Error:', error);
      alert('Sorry, failed to add bundle to cart. Please try again.');
    } finally {
      btn.innerText = originalText;
      btn.disabled = false;
    }
  });
</script>

{% schema %}
{
  "name": "Bundle builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "product",
      "label": "Product"
    }
  ]
}
{% endschema %}
